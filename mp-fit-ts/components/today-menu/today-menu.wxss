/* ===== 今日菜单组件样式 ===== */

.today-menu-container {
  padding: 16rpx 24rpx 12rpx;
}

/* -- 控制区 -- */
.menu-ctrl-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* -- Tier 1: 分段控制器 -- */
.segmented-ctrl {
  display: flex;
  background: #f2f3f5;
  border-radius: 10rpx;
  padding: 4rpx;
  margin-bottom: 12rpx;
}

.seg-btn {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #909399;
}

.seg-on {
  background: #fff;
  color: #303133;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.10);
}

/* -- Tier 2: 日期导航 -- */
.date-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.date-arrow {
  padding: 8rpx 16rpx;
  background: #f7f8fa;
  border: 1rpx solid #e8eaed;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #606266;
}

.date-arrow:active {
  border-color: #409eff;
  color: #409eff;
  background: #ecf5ff;
}

.date-display {
  padding: 8rpx 16rpx;
}

.date-display text {
  font-size: 26rpx;
  font-weight: 700;
  color: #303133;
}

.date-display:active text {
  color: #409eff;
}

.back-home-row {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}

.back-today-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border: 2rpx solid #409eff;
  background: #ecf5ff;
  border-radius: 28rpx;
}

.back-today-btn text {
  font-size: 22rpx;
  color: #409eff;
  font-weight: 600;
}

@keyframes breathe {
  0%, 100% { box-shadow: 0 0 0 0 rgba(64,158,255,0.45); }
  50%     { box-shadow: 0 0 0 12rpx rgba(64,158,255,0); }
}

.breathing {
  animation: breathe 2s ease-in-out infinite;
}

/* -- Tier 3: 餐次胶囊 -- */
.capsule-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
}

.capsule {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 10rpx 4rpx;
  border: 2rpx solid #e4e7ed;
  background: #fafbfc;
  border-radius: 28rpx;
}

.capsule:active {
  border-color: #c0c4cc;
  background: #f3f4f5;
}

.capsule-ico { font-size: 22rpx; }

.capsule-lbl {
  font-size: 22rpx;
  color: #909399;
  font-weight: 500;
}

/* 选中态 */
.capsule-on {
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.capsule-breakfast.capsule-on {
  border-color: #e6a23c;
  background: #fef8ed;
}
.capsule-breakfast.capsule-on .capsule-lbl { color: #b88230; }

.capsule-lunch.capsule-on {
  border-color: #e67e22;
  background: #fef4ea;
}
.capsule-lunch.capsule-on .capsule-lbl { color: #b8661a; }

.capsule-dinner.capsule-on {
  border-color: #8e44ad;
  background: #f7effa;
}
.capsule-dinner.capsule-on .capsule-lbl { color: #713690; }

.capsule-supper.capsule-on {
  border-color: #5b6abf;
  background: #eff1fa;
}
.capsule-supper.capsule-on .capsule-lbl { color: #4958a3; }

/* ===== 骨架屏 ===== */
.menu-skel-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-skel-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.sk-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  border-bottom: 3rpx solid #ebeef5;
  background: #fafbfc;
}

.sk-body {
  padding: 14rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sk-bar {
  height: 14rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #eee 25%, #e0e0e0 50%, #eee 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

.sk-bar-title { width: 55%; height: 20rpx; }
.sk-bar-badge { width: 90rpx; border-radius: 12rpx; }
.sk-bar-name  { width: 70%; }
.sk-bar-info  { width: 90%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 空状态 ===== */
.menu-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-ico {
  font-size: 90rpx;
  display: block;
  opacity: 0.5;
  margin-bottom: 22rpx;
}

.floating {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-10rpx); }
}

.empty-msg {
  font-size: 26rpx;
  font-weight: 500;
  color: #909399;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* ===== 分类卡片网格 ===== */
.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* -- 单张分类卡片 -- */
.menu-card {
  background: #fff;
  border-radius: 14rpx;
  box-shadow: 0 3rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #ebeef5;
}

/* -- 卡片头部 -- */
.menu-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-bottom: 3rpx solid #e67e22;
  background: #fafbfc;
}

.menu-card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.menu-card-num {
  font-size: 20rpx;
  color: #909399;
  background: #ecedf1;
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
  font-weight: 600;
}

/* -- 卡片内容 -- */
.menu-card-body {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx 0;
}

/* -- 菜品行 -- */
.dish {
  width: 50%;
  box-sizing: border-box;
  padding: 14rpx 20rpx;
  border-bottom: 1rpx solid #f2f3f5;
  border-right: 1rpx solid #f2f3f5;
  position: relative;
}

.dish:nth-child(2n) {
  border-right: none;
}

/* 辣菜高亮 */
.dish-hot {
  background: #fffaf9;
}

/* 菜名行 */
.dish-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.dish-name {
  font-size: 22rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.3;
}

/* 辣标签 */
.hot-tag {
  display: inline-flex;
  align-items: center;
  background: #fef0f0;
  border: 1rpx solid #fbc4c4;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  flex-shrink: 0;
}

.hot-tag text {
  font-size: 20rpx;
  font-weight: 800;
  color: #f56c6c;
}

/* 浮动延申浮窗 */
.dish-expand {
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  transform: translateX(-50%) translateY(100%);
  z-index: 20;
  animation: floatIn 0.25s ease-out;
  white-space: nowrap;
}

@keyframes floatIn {
  0%   { opacity: 0; transform: translateX(-50%) translateY(80%); }
  100% { opacity: 1; transform: translateX(-50%) translateY(100%); }
}

.dish-expand-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
}

/* 收藏按钮 */
.fav-star-btn {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  background: #f5f6f8;
  border: 2rpx solid #e4e7ed;
  transition: all 0.2s;
}

.fav-star-btn:active {
  transform: scale(0.96);
}

.fav-star-btn-on {
  background: #fef8ed;
  border-color: #f5dab1;
}

.fav-star-icon {
  font-size: 32rpx;
  line-height: 1;
}

.fav-star-on {
  /* 实心高亮 */
}

.fav-star-off {
  filter: grayscale(100%) opacity(0.35);
}

.fav-star-text {
  font-size: 22rpx;
  font-weight: 500;
  color: #909399;
}

.fav-star-btn-on .fav-star-text {
  color: #e6a23c;
}

/* 价格 + 热量行 */
.dish-bot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #e67e22;
}

.dish-price-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #909399;
  margin-left: 2rpx;
}

.dish-kcal {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #909399;
}

/* 热量三色 */
.dish-kcal.cal-low {
  color: #57a52a;
  background: #ebf7e3;
}

.dish-kcal.cal-high {
  color: #d46b08;
  background: #fef0dc;
  font-weight: 700;
}

.dish-kcal.cal-mid {
  color: #909399;
  background: #f5f7fa;
}

/* ===== 欢迎品尝卡片 ===== */
.welcome-card {
  background: transparent;
  border: none;
  box-shadow: none;
  border-radius: 0;
  margin-bottom: 20rpx;
}

.welcome-text {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
}

.welcome-text-inner {
  font-size: 28rpx;
  font-weight: 700;
  color: #909399;
  letter-spacing: 4rpx;
}
