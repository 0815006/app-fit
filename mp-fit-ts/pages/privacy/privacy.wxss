page {
  background: #f5f6f8;
}

.privacy-page {
  min-height: 100vh;
  padding: 24rpx;
}

.privacy-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
}

.privacy-section {
  margin-bottom: 36rpx;
}

.privacy-section:last-child {
  margin-bottom: 0;
}

.privacy-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.privacy-section-content {
  padding-left: 4rpx;
}

.privacy-line {
  display: block;
  font-size: 28rpx;
  color: #606266;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

.privacy-line-break {
  height: 16rpx;
}
