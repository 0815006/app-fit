<view class="container">
  <scroll-view scroll-y class="main-scroll" style="height: {{ scrollHeight }}px">
  <!-- ========== 健身打卡 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'fitness' }}">
    <!-- 坚持榜双卡片 -->
    <view class="consistency-cards">
      <!-- 连续打卡 -->
      <view class="consistency-card cc-card-streak">
        <view class="cc-header cc-header-streak">
          <text class="cc-header-icon">🏅</text>
          <text class="cc-header-title">连续打卡</text>
        </view>
        <scroll-view scroll-y class="cc-body">
          <block wx:if="{{ streakData.length > 0 }}">
            <view class="cc-row" wx:for="{{ streakData }}" wx:key="userId">
              <view class="cc-rank-col">
                <text wx:if="{{ index === 0 }}" class="cc-medal">🥇</text>
                <text wx:elif="{{ index === 1 }}" class="cc-medal">🥈</text>
                <text wx:elif="{{ index === 2 }}" class="cc-medal">🥉</text>
                <text wx:else class="cc-rank">{{ index + 1 }}</text>
              </view>
              <text class="cc-name">{{ item.nickname || item.empName || item.empNo }}</text>
              <text class="cc-value">{{ item.value }}<text class="cc-unit">天</text></text>
            </view>
          </block>
          <view class="cc-empty" wx:else>
            <text>暂无数据</text>
          </view>
        </scroll-view>
      </view>
      <!-- 累计打卡 -->
      <view class="consistency-card cc-card-cumulative">
        <view class="cc-header cc-header-cumulative">
          <text class="cc-header-icon">🏆</text>
          <text class="cc-header-title">累计打卡</text>
        </view>
        <scroll-view scroll-y class="cc-body">
          <block wx:if="{{ cumulativeData.length > 0 }}">
            <view class="cc-row" wx:for="{{ cumulativeData }}" wx:key="userId">
              <view class="cc-rank-col">
                <text wx:if="{{ index === 0 }}" class="cc-medal">🥇</text>
                <text wx:elif="{{ index === 1 }}" class="cc-medal">🥈</text>
                <text wx:elif="{{ index === 2 }}" class="cc-medal">🥉</text>
                <text wx:else class="cc-rank">{{ index + 1 }}</text>
              </view>
              <text class="cc-name">{{ item.nickname || item.empName || item.empNo }}</text>
              <text class="cc-value">{{ item.value }}<text class="cc-unit">天</text></text>
            </view>
          </block>
          <view class="cc-empty" wx:else>
            <text>暂无数据</text>
          </view>
        </scroll-view>
      </view>
    </view>
    <!-- 更多榜单入口 -->
    <view class="more-ranking-entry" bindtap="navigateToRanking">
      <view class="hub-card-icon">🏆</view>
      <view class="hub-card-body">
        <text class="hub-card-title">更多榜单</text>
        <text class="hub-card-desc">坚持榜 · 容量榜 · 1RM巅峰榜 · 进步榜</text>
      </view>
      <view class="hub-card-arrow">›</view>
    </view>

    <!-- 下方双栏区域 -->
    <view class="workout-hub-bottom">
      <!-- 左侧：今日打卡 + 补记录 -->
      <view class="workout-hub-left">
        <view class="workout-hub-card workout-hub-checkin" bindtap="navigateToCheckin">
          <view class="hub-card-icon">📋</view>
          <view class="hub-card-body">
            <text class="hub-card-title">今日打卡</text>
            <text class="hub-card-desc">选择肌群 · 开始训练</text>
          </view>
          <view class="hub-card-arrow">›</view>
        </view>
        <view class="workout-hub-card workout-hub-makeup" bindtap="navigateToMakeup">
          <view class="hub-card-icon">📝</view>
          <view class="hub-card-body">
            <text class="hub-card-title">自由补打卡</text>
          </view>
          <view class="hub-card-arrow">›</view>
        </view>
      </view>

      <!-- 右侧：本周健身记录 + 我的所有记录 -->
      <view class="workout-hub-right">
        <view class="workout-hub-card workout-hub-weekly" bindtap="navigateToWeekly">
          <view class="hub-card-icon">📊</view>
          <view class="hub-card-body">
            <text class="hub-card-title">本周健身记录</text>
            <text class="hub-card-desc">训练概览 · 7日视图</text>
          </view>
          <view class="hub-card-arrow">›</view>
        </view>
        <view class="workout-hub-card workout-hub-calendar" bindtap="navigateToCalendar">
          <view class="hub-card-icon">📅</view>
          <view class="hub-card-body">
            <text class="hub-card-title">我的所有记录</text>
          </view>
          <view class="hub-card-arrow">›</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ========== 个人信息 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'tech' }}">
    <!-- 当前用户信息卡片（点击进入个人信息页） -->
    <view class="user-info-card" wx:if="{{ currentUser }}" bindtap="goToProfile">
      <view class="user-info-avatar">
        <image wx:if="{{ currentUser.avatarUrl }}" class="user-avatar-img" src="{{ currentUser.avatarUrl }}" mode="aspectFill" />
        <text wx:else class="user-avatar-placeholder">👤</text>
      </view>
      <view class="user-info-body">
        <text class="user-info-name">{{ currentUser.nickname || '未设置昵称' }}</text>
        <text class="user-info-hint">点击查看/编辑个人信息 →</text>
      </view>
      <view class="user-info-arrow">></view>
    </view>

    <!-- 登录统计卡片 -->
    <view class="stats-card">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{ myLoginCount !== null ? myLoginCount : '--' }}</text>
          <text class="stats-label">我的登录次数</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value stats-value-total">{{ totalLoginCount !== null ? totalLoginCount : '--' }}</text>
          <text class="stats-label">小程序总登录次数</text>
        </view>
      </view>
      <view class="stats-hint" wx:if="{{ statsLoading }}">
        <text>加载中...</text>
      </view>
    </view>

    <!-- 关于 -->
    <view class="about-section">
      <view class="about-header">
        <text class="about-title">关于</text>
      </view>
      <view class="about-item" bindtap="goToPrivacy">
        <text class="about-item-label">隐私保护协议</text>
        <text class="about-item-arrow">›</text>
      </view>
      <view class="about-item" bindtap="toggleTechDetail">
        <text class="about-item-label">技术选型</text>
        <text class="about-item-arrow {{ techDetailOpen ? 'about-item-arrow-open' : '' }}">{{ techDetailOpen ? '˅' : '›' }}</text>
      </view>
      <view class="about-tech-list" wx:if="{{ techDetailOpen }}">
        <view class="tech-row" wx:for="{{ techStack }}" wx:key="name">
          <view class="tech-left">
            <text class="tech-category">{{ item.category }}</text>
            <text class="tech-name">{{ item.name }}</text>
          </view>
          <view class="tech-right">
            <text class="tech-version">{{ item.version }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  </scroll-view>

  <!-- 底部菜单栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{ activeTab === item.key ? 'tab-item-active' : '' }}"
      wx:for="{{ tabBars }}"
      wx:key="key"
      data-key="{{ item.key }}"
      bindtap="switchTab"
    >
      <text class="tab-icon">{{ item.icon }}</text>
      <text class="tab-label">{{ item.label }}</text>
    </view>
  </view>
  <!-- 资料完善弹窗 -->
  <profile-completion
    visible="{{ showProfileModal }}"
    bind:close="onProfileClose"
    bind:success="onProfileSuccess"
  />
</view>
