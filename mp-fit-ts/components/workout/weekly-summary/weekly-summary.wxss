/* ===== 本周健身记录组件 ===== */

/* ── 加载 ── */
.weekly-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.weekly-loading text {
  font-size: 24rpx;
  color: #909399;
}

/* ── 内容 ── */
.weekly-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ── 按天分组 ── */
.weekly-day-group {
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.weekly-day-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  background: #fafbfc;
  border-bottom: 1rpx solid #f0f0f0;
}

.weekly-day-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #303133;
}

.weekly-day-count {
  font-size: 20rpx;
  color: #909399;
  background: #ecedf1;
  border-radius: 12rpx;
  padding: 4rpx 14rpx;
}

/* ── 训练记录卡片 ── */
.weekly-record-card {
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.weekly-record-card:last-child {
  border-bottom: none;
}

.weekly-record-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.weekly-record-action {
  font-size: 26rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.3;
}

.weekly-record-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
}

.weekly-record-muscle {
  font-size: 20rpx;
  color: #909399;
  background: #f5f6f8;
  border-radius: 4rpx;
  padding: 2rpx 10rpx;
}

.weekly-record-info {
  font-size: 20rpx;
  color: #606266;
  font-weight: 500;
}

.weekly-record-right {
  flex-shrink: 0;
  margin-left: 12rpx;
}

.weekly-record-pr {
  font-size: 24rpx;
  color: #e6a23c;
  font-weight: 700;
}

.weekly-record-burst {
  font-size: 24rpx;
}

.weekly-record-hot {
  font-size: 24rpx;
}

/* ── 空状态 ── */
.weekly-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.weekly-empty-ico {
  font-size: 80rpx;
  display: block;
  opacity: 0.5;
  margin-bottom: 22rpx;
}

.weekly-empty-msg {
  font-size: 26rpx;
  font-weight: 500;
  color: #909399;
  margin-bottom: 10rpx;
}

.weekly-empty-hint {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* ── 底部统计栏 ── */
.weekly-stats-bar {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #b37feb, #9254de);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(179, 127, 235, 0.3);
}

.weekly-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.weekly-stat-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.weekly-stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.weekly-stat-divider {
  width: 2rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}
