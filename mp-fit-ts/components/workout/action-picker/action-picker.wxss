/* ===== 底部弹出面板 ===== */

.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 300;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.picker-panel {
  width: 100%;
  height: 75vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: pickerSlideUp 0.25s ease-out;
}

@keyframes pickerSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* ── 标题栏 ── */
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 18rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #303133;
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f6f8;
}

.picker-close:active {
  background: #e8eaed;
}

.picker-close text {
  font-size: 24rpx;
  color: #909399;
}

/* ── 加载 ── */
.picker-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.picker-loading text {
  font-size: 24rpx;
  color: #909399;
}

/* ── 列表容器 ── */
.picker-list {
  flex: 1;
  height: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* ── 高亮区域 ── */
.picker-highlight-section {
  margin-bottom: 20rpx;
  border: 2rpx solid #e6a23c;
  border-radius: 14rpx;
  overflow: hidden;
  background: linear-gradient(to right, rgba(230, 162, 60, 0.06), transparent);
}

.picker-highlight-header {
  padding: 14rpx 20rpx;
  background: linear-gradient(135deg, #fdf6ec, #fef0dc);
  border-bottom: 1rpx solid #f5dab1;
}

.picker-highlight-header text {
  font-size: 24rpx;
  font-weight: 700;
  color: #b88230;
}

/* ── 常规区域 ── */
.picker-normal-section {
  margin-top: 8rpx;
}

.picker-normal-header {
  padding: 12rpx 8rpx 16rpx;
}

.picker-normal-header text {
  font-size: 22rpx;
  color: #c0c4cc;
  font-weight: 500;
}

.picker-hint {
  padding: 40rpx 0;
  text-align: center;
}

.picker-hint text {
  font-size: 24rpx;
  color: #909399;
}

/* ── 动作卡片（通用） ── */
.picker-action-card {
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid #ebeef5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 12rpx;
}

.picker-action-card:active {
  background: #f5f7fa;
}

.picker-action-highlighted {
  border-color: #f5dab1;
  background: rgba(253, 246, 236, 0.4);
}

.picker-action-highlighted:active {
  background: rgba(253, 246, 236, 0.7);
}

.picker-action-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.picker-action-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.3;
}

.picker-action-alias {
  font-size: 20rpx;
  color: #c0c4cc;
  margin-top: 2rpx;
}

.picker-action-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-top: 6rpx;
}

.picker-action-equip-tag {
  font-size: 18rpx;
  color: #5470c6;
  background: #edf2fc;
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
  border: 1rpx solid #d0d9f0;
}

.picker-action-btn {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #409eff, #337ecc);
  border-radius: 8rpx;
}

.picker-action-btn:active {
  background: linear-gradient(135deg, #337ecc, #2b6cb0);
}

.picker-action-btn text {
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
}

/* ── 空状态 ── */
.picker-empty {
  padding: 60rpx 0;
  text-align: center;
}

.picker-empty-text {
  font-size: 24rpx;
  color: #909399;
}
