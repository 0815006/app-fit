/* ===== 会议预定组件样式 ===== */

.meeting-booking-container {
  padding: 16rpx 24rpx 12rpx;
}

/* 加载 */
.loading-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #909399;
}

/* ── 控制区 ── */
.meeting-ctrl-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 日期导航 */
.date-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.date-arrow {
  padding: 8rpx 16rpx;
  background: #f7f8fa;
  border: 1rpx solid #e8eaed;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #606266;
}

.date-arrow:active {
  border-color: #409eff;
  color: #409eff;
  background: #ecf5ff;
}

.date-display {
  padding: 8rpx 16rpx;
}

.date-display text {
  font-size: 26rpx;
  font-weight: 700;
  color: #303133;
}

.date-display:active text {
  color: #409eff;
}

.back-home-row {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}

.back-today-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border: 2rpx solid #409eff;
  background: #ecf5ff;
  border-radius: 28rpx;
}

.back-today-btn text {
  font-size: 22rpx;
  color: #409eff;
  font-weight: 600;
}

@keyframes breathe {
  0%, 100% { box-shadow: 0 0 0 0 rgba(64,158,255,0.45); }
  50%     { box-shadow: 0 0 0 12rpx rgba(64,158,255,0); }
}

.breathing {
  animation: breathe 2s ease-in-out infinite;
}

/* 会议室选择器（横向滚动） */
.meeting-room-tabs {
  width: 100%;
  white-space: nowrap;
}

.meeting-room-tabs-inner {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 0;
}

.meeting-room-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  background: #f5f6f8;
  border: 2rpx solid #e8eaed;
  flex-shrink: 0;
  min-width: 130rpx;
}

.meeting-room-tab:active {
  background: #ecedf1;
}

.meeting-room-tab-active {
  background: linear-gradient(135deg, #409eff, #337ecc);
  border-color: #337ecc;
  box-shadow: 0 4rpx 16rpx rgba(64, 158, 255, 0.35);
}

.meeting-room-tab-active .meeting-room-tab-name {
  color: #fff;
  font-weight: 700;
}

.meeting-room-tab-active .meeting-room-tab-cap {
  color: rgba(255, 255, 255, 0.8);
}

.meeting-room-tab-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #303133;
}

.meeting-room-tab-cap {
  font-size: 18rpx;
  color: #909399;
  margin-top: 2rpx;
}

/* ── 会议室信息条 ── */
.meeting-room-info-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  padding: 14rpx 24rpx;
  background: #fafbfc;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid #ebeef5;
}

.meeting-room-info-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #303133;
}

.meeting-room-info-cap {
  font-size: 22rpx;
  color: #909399;
  background: #ecedf1;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.meeting-room-info-facilities {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.meeting-facility-tag {
  font-size: 20rpx;
  color: #409eff;
  background: #ecf5ff;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  border: 1rpx solid #d9ecff;
}

/* 视图切换（信息条内联） */
.meeting-view-toggle-inline {
  margin-left: auto;
  font-size: 22rpx;
  color: #409eff;
  background: #ecf5ff;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  border: 1rpx solid #d9ecff;
  flex-shrink: 0;
}

.meeting-view-toggle-inline:active {
  background: #d9ecff;
}

/* ── 图例 ── */
.meeting-legend {
  display: flex;
  gap: 20rpx;
  padding: 10rpx 6rpx 16rpx;
  flex-wrap: wrap;
}

.meeting-legend-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.meeting-legend-item text {
  font-size: 20rpx;
  color: #909399;
}

.meeting-legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
}

.meeting-legend-free {
  background: #f0f9eb;
  border: 1rpx solid #c2e7b0;
}

.meeting-legend-mine {
  background: #d9ecff;
  border: 1rpx solid #b3d8ff;
}

.meeting-legend-booked {
  background: #f5f5f5;
  border: 1rpx solid #dcdfe6;
}

.meeting-legend-lock {
  background: repeating-linear-gradient(
    45deg,
    #fef0f0,
    #fef0f0 4rpx,
    #fde2e2 4rpx,
    #fde2e2 8rpx
  );
  border: 1rpx solid #fab6b6;
}

/* ── 时间网格表格 ── */
.meeting-grid-wrap {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
  padding-bottom: 8rpx;
}

.meeting-grid-table {
  display: flex;
  flex-direction: column;
}

/* ── 午休分隔线 ── */
.meeting-divider {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}

.meeting-divider-line {
  flex: 1;
  height: 1rpx;
  background: #dcdfe6;
}

.meeting-divider-text {
  margin: 0 16rpx;
  font-size: 20rpx;
  color: #b0b3b8;
  white-space: nowrap;
}

/* ── 合并行：左整点标签 + 右两段左右并排 ── */
.meeting-hour-row {
  display: flex;
  border-bottom: 1rpx solid #f2f3f5;
  min-height: 74rpx;
}

/* 时间标签列 */
.meeting-hour-label-col {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1rpx solid #ebeef5;
  background: #fafbfc;
}

.meeting-hour-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #909399;
  white-space: nowrap;
}

/* 右侧格子容器（flex row） */
.meeting-hour-cells {
  flex: 1;
  display: flex;
}

/* 单个半小时格子 */
.meeting-slot-cell {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 6rpx 10rpx;
  border-right: 1rpx solid #ebeef5;
  min-height: 74rpx;
}

.meeting-slot-cell:last-child {
  border-right: none;
}

.meeting-slot-cell:active {
  opacity: 0.7;
}

.meeting-slot-cell-past {
  opacity: 0.45;
}

.meeting-slot-cell-past:active {
  opacity: 0.35;
}

/* 状态配色 */
.meeting-slot-cell-mine {
  background: #ecf5ff;
}

.meeting-slot-cell-booked {
  background: #f5f5f5;
}

.meeting-slot-cell-lock {
  background: repeating-linear-gradient(
    45deg,
    #fef0f0,
    #fef0f0 4rpx,
    #fde2e2 4rpx,
    #fde2e2 8rpx
  );
}

.meeting-slot-cell-free {
  background: #f0f9eb;
}

/* 空占位 */
.meeting-slot-cell-placeholder {
  opacity: 0.25;
}

/* 空闲状态文字 */
.meeting-slot-status-free {
  font-size: 22rpx;
  color: #67c23a;
  font-weight: 500;
  align-self: center;
}

/* 已过期文字 */
.meeting-slot-status-past {
  font-size: 22rpx;
  color: #c0c4cc;
  align-self: center;
}

/* 预定人名/会议标题 */
.meeting-slot-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meeting-slot-cell-mine .meeting-slot-name {
  color: #409eff;
}

.meeting-slot-cell-booked .meeting-slot-name {
  color: #909399;
}

.meeting-slot-cell-lock .meeting-slot-name {
  color: #f56c6c;
}

/* 副标题 */
.meeting-slot-sub {
  font-size: 20rpx;
  color: #909399;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 周期标签 */
.meeting-slot-weekly {
  margin-top: 2rpx;
}

.meeting-slot-weekly text {
  font-size: 18rpx;
  color: #e6a23c;
  background: #fdf6ec;
  border-radius: 4rpx;
  padding: 1rpx 8rpx;
  border: 1rpx solid #f5dab1;
}

/* ── 弹窗 ── */
.meeting-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.meeting-modal {
  width: 100%;
  max-height: 75vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.meeting-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 18rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.meeting-modal-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #303133;
}

.meeting-modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f5f6f8;
}

.meeting-modal-close:active {
  background: #e8eaed;
}

.meeting-modal-close text {
  font-size: 24rpx;
  color: #909399;
}

/* 时间信息 */
.meeting-modal-time-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 28rpx;
  background: #fafbfc;
  border-bottom: 1rpx solid #f0f0f0;
}

.meeting-modal-time-label {
  font-size: 24rpx;
  color: #303133;
  font-weight: 600;
}

.meeting-modal-time-end {
  font-size: 22rpx;
  color: #909399;
}

.meeting-modal-time-badge {
  margin-left: auto;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.meeting-modal-badge-free {
  background: #f0f9eb;
  color: #67c23a;
  border: 1rpx solid #c2e7b0;
}

.meeting-modal-badge-mine {
  background: #ecf5ff;
  color: #409eff;
  border: 1rpx solid #d9ecff;
}

.meeting-modal-badge-booked {
  background: #f5f5f5;
  color: #909399;
  border: 1rpx solid #dcdfe6;
}

.meeting-modal-badge-lock {
  background: #fef0f0;
  color: #f56c6c;
  border: 1rpx solid #fbc4c4;
}

/* 弹窗内容 */
.meeting-modal-section {
  padding: 20rpx 28rpx;
  max-height: 40vh;
  overflow-y: auto;
}

.meeting-modal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.meeting-modal-label {
  font-size: 24rpx;
  color: #909399;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.meeting-modal-value {
  font-size: 24rpx;
  color: #303133;
  font-weight: 500;
  text-align: right;
  word-break: break-all;
}

.meeting-modal-tag-weekly {
  color: #e6a23c;
  background: none;
}

/* 周期例会开关（缩小） */
.meeting-modal-switch {
  transform: scale(0.7);
  margin-left: auto;
}

/* 表单字段 */
.meeting-modal-field {
  padding: 12rpx 0;
}

.meeting-modal-field .meeting-modal-row {
  padding: 0;
}

.meeting-modal-input {
  width: 100%;
  height: 72rpx;
  background: #f5f6f8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #303133;
  margin-top: 8rpx;
  box-sizing: border-box;
}

.meeting-modal-input-sm {
  width: 160rpx;
  display: inline-block;
}

.meeting-modal-hint {
  font-size: 20rpx;
  color: #c0c4cc;
  margin-left: 12rpx;
}

/* 弹窗按钮 */
.meeting-modal-footer {
  padding: 18rpx 28rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.meeting-modal-footer-full {
  display: flex;
  gap: 16rpx;
}

.meeting-modal-footer-edit {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meeting-modal-footer-edit .meeting-modal-btn-cancel {
  flex: 0 0 auto;
}

.meeting-modal-footer-edit .meeting-modal-btn-danger {
  flex: 1;
}

.meeting-modal-footer-edit .meeting-modal-btn-primary {
  flex: 1;
  width: 100%;
  min-width: 100%;
}

.meeting-modal-btn-cancel {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  background: #f5f6f8;
  border-radius: 12rpx;
}

.meeting-modal-btn-cancel:active {
  background: #e8eaed;
}

.meeting-modal-btn-cancel text {
  font-size: 26rpx;
  font-weight: 500;
  color: #909399;
}

.meeting-modal-btn-primary {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  background: linear-gradient(135deg, #409eff, #337ecc);
  border-radius: 12rpx;
}

.meeting-modal-btn-primary:active {
  background: linear-gradient(135deg, #337ecc, #2b6cb0);
}

.meeting-modal-btn-primary text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.meeting-modal-btn-danger {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0;
  background: #fef0f0;
  border: 1rpx solid #fbc4c4;
  border-radius: 12rpx;
}

.meeting-modal-btn-danger:active {
  background: #fde2e2;
}

.meeting-modal-btn-danger text {
  font-size: 26rpx;
  font-weight: 500;
  color: #f56c6c;
}

/* ===== 空状态 (共用) ===== */

.menu-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-ico {
  font-size: 90rpx;
  display: block;
  opacity: 0.5;
  margin-bottom: 22rpx;
}

.empty-msg {
  font-size: 26rpx;
  font-weight: 500;
  color: #909399;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #c0c4cc;
}
