/* 个人信息页面样式 */
page {
  background: #f5f6f8;
  height: 100vh;
}

.profile-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 加载 */
.loading-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #909399;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  line-height: 1;
}

.avatar-wrapper::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #f0f2f5;
  margin-bottom: 16rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  margin-bottom: 16rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 24rpx;
  color: #409eff;
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  flex-wrap: wrap;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  padding: 0;
}

.form-input::placeholder {
  color: #c0c4cc;
}

.form-hint {
  width: 100%;
  margin-top: 10rpx;
  margin-left: 120rpx;
  font-size: 22rpx;
  color: #e6a23c;
  font-style: italic;
}

/* 操作按钮 */
.action-section {
  padding: 40rpx 30rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #409eff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: #a0cfff;
}
