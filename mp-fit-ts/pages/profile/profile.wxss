/* 个人信息页面样式 */
page {
  background: #f5f6f8;
  height: 100vh;
}

.profile-page {
  min-height: 100vh;
  padding: 0 24rpx 40rpx;
}

/* 加载 */
.loading-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 200rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #909399;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0 36rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 4rpx solid #e8e8e8;
  overflow: hidden;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: #f0f2f5;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin-bottom: 20rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
  flex-wrap: wrap;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  padding: 0;
}

.form-input::placeholder {
  color: #c0c4cc;
}

.form-hint {
  width: 100%;
  margin-top: 10rpx;
  margin-left: 120rpx;
  font-size: 22rpx;
  color: #e6a23c;
  font-style: italic;
}

/* 操作按钮 */
.action-section {
  padding: 40rpx 24rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: #409eff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.save-btn::after {
  border: none;
}

.save-btn[disabled] {
  background: #a0cfff;
}

/* 隐私阻断区域 */
.privacy-blocked {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.blocked-icon {
  font-size: 80rpx;
  margin-bottom: 28rpx;
}

.blocked-text {
  font-size: 28rpx;
  color: #606266;
  text-align: center;
  margin-bottom: 40rpx;
  line-height: 44rpx;
}

.retry-btn {
  width: 360rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #fff;
  background: #409eff;
  border: none;
  border-radius: 12rpx;
  padding: 0;
}

.retry-btn::after {
  border: none;
}

