/* ===== 全局 / 公共 ===== */

page {
  background: #f5f6f8;
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.main-scroll {
  flex-shrink: 0;
  padding: 16rpx 20rpx 0;
}

.content-area {
  padding-bottom: 12rpx;
}

/* 加载 */
.loading-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #909399;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  padding: 22rpx 26rpx 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 26rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label {
  font-size: 26rpx;
  color: #606266;
}

.info-value {
  font-size: 26rpx;
  color: #303133;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.tag-primary {
  background: #ecf5ff;
  color: #409eff;
  border: 1rpx solid #d9ecff;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #ebeef5;
  margin: 14rpx 26rpx;
}

/* 统计 */
.stat-area {
  text-align: center;
  padding: 24rpx 0 12rpx;
}

.count-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #409eff;
}

.count-unit {
  font-size: 28rpx;
  color: #909399;
  margin-left: 6rpx;
}

.stat-hint {
  text-align: center;
  padding-bottom: 22rpx;
}

.stat-hint text {
  font-size: 20rpx;
  color: #c0c4cc;
}

/* 技术选型 */
.tech-list {
  padding: 0 0 6rpx;
}

.tech-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 26rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.tech-row:last-child {
  border-bottom: none;
}

.tech-left {
  display: flex;
  flex-direction: column;
}

.tech-category {
  font-size: 24rpx;
  color: #303133;
}

.tech-name {
  font-size: 20rpx;
  color: #909399;
  margin-top: 4rpx;
}

.tech-right { flex-shrink: 0; }

.tech-version {
  font-size: 22rpx;
  color: #c0c4cc;
  background: #f5f7fa;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

/* 底部菜单栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e4e7ed;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  color: #909399;
}

.tab-item-active { color: #409eff; }

.tab-icon  { font-size: 32rpx; }
.tab-label { font-size: 20rpx; margin-top: 2rpx; }

/* ===== 今日菜单 - 控制区 ===== */

.menu-ctrl-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 18rpx 18rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* -- Tier 1: 分段控制器 -- */
.segmented-ctrl {
  display: flex;
  background: #f2f3f5;
  border-radius: 10rpx;
  padding: 4rpx;
  margin-bottom: 12rpx;
}

.seg-btn {
  flex: 1;
  text-align: center;
  padding: 10rpx 0;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #909399;
}

.seg-on {
  background: #fff;
  color: #303133;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.10);
}

/* -- Tier 2: 日期导航 -- */
.date-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.date-arrow {
  padding: 8rpx 16rpx;
  background: #f7f8fa;
  border: 1rpx solid #e8eaed;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #606266;
}

.date-arrow:active {
  border-color: #409eff;
  color: #409eff;
  background: #ecf5ff;
}

.date-display {
  padding: 8rpx 16rpx;
}

.date-display text {
  font-size: 26rpx;
  font-weight: 700;
  color: #303133;
}

.date-display:active text {
  color: #409eff;
}

.back-home-row {
  display: flex;
  justify-content: center;
  margin-bottom: 12rpx;
}

.back-today-btn {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border: 2rpx solid #409eff;
  background: #ecf5ff;
  border-radius: 28rpx;
}

.back-today-btn text {
  font-size: 22rpx;
  color: #409eff;
  font-weight: 600;
}

@keyframes breathe {
  0%, 100% { box-shadow: 0 0 0 0 rgba(64,158,255,0.45); }
  50%     { box-shadow: 0 0 0 12rpx rgba(64,158,255,0); }
}

.breathing {
  animation: breathe 2s ease-in-out infinite;
}

/* -- Tier 3: 餐次胶囊 (compact 1-row) -- */
.capsule-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 8rpx;
}

.capsule {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 10rpx 4rpx;
  border: 2rpx solid #e4e7ed;
  background: #fafbfc;
  border-radius: 28rpx;
}

.capsule:active {
  border-color: #c0c4cc;
  background: #f3f4f5;
}

.capsule-ico { font-size: 22rpx; }

.capsule-lbl {
  font-size: 22rpx;
  color: #909399;
  font-weight: 500;
}

/* 选中态 */
.capsule-on {
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.capsule-breakfast.capsule-on {
  border-color: #e6a23c;
  background: #fef8ed;
}
.capsule-breakfast.capsule-on .capsule-lbl { color: #b88230; }

.capsule-lunch.capsule-on {
  border-color: #e67e22;
  background: #fef4ea;
}
.capsule-lunch.capsule-on .capsule-lbl { color: #b8661a; }

.capsule-dinner.capsule-on {
  border-color: #8e44ad;
  background: #f7effa;
}
.capsule-dinner.capsule-on .capsule-lbl { color: #713690; }

.capsule-supper.capsule-on {
  border-color: #5b6abf;
  background: #eff1fa;
}
.capsule-supper.capsule-on .capsule-lbl { color: #4958a3; }

/* ===== 骨架屏 ===== */

.menu-skel-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-skel-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.sk-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 22rpx;
  border-bottom: 3rpx solid #ebeef5;
  background: #fafbfc;
}

.sk-body {
  padding: 14rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.sk-bar {
  height: 14rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #eee 25%, #e0e0e0 50%, #eee 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
}

.sk-bar-title { width: 55%; height: 20rpx; }
.sk-bar-badge { width: 90rpx; border-radius: 12rpx; }
.sk-bar-name  { width: 70%; }
.sk-bar-info  { width: 90%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 空状态 ===== */

.menu-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-ico {
  font-size: 90rpx;
  display: block;
  opacity: 0.5;
  margin-bottom: 22rpx;
}

.floating {
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-10rpx); }
}

.empty-msg {
  font-size: 26rpx;
  font-weight: 500;
  color: #909399;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* ===== 分类卡片网格 ===== */

.menu-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* -- 单张分类卡片 -- */
.menu-card {
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 3rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #ebeef5;
}

/* -- 卡片头部 -- */
.menu-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 22rpx;
  border-bottom: 3rpx solid #e67e22;
  background: #fafbfc;
}

.menu-card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.menu-card-num {
  font-size: 20rpx;
  color: #909399;
  background: #ecedf1;
  border-radius: 16rpx;
  padding: 4rpx 14rpx;
  font-weight: 600;
}

/* -- 卡片内容 -- */
.menu-card-body {
  padding: 4rpx 0;
}

/* -- 菜品行 -- */
.dish {
  padding: 14rpx 22rpx;
  border-bottom: 1rpx solid #f2f3f5;
}

.dish:last-child {
  border-bottom: none;
}

/* 辣菜高亮 */
.dish-hot {
  background: #fffaf9;
  border-left: 5rpx solid #f56c6c;
  padding-left: 17rpx;
}

/* 菜名行 */
.dish-top {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.dish-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.3;
}

/* 辣标签 */
.hot-tag {
  display: inline-flex;
  align-items: center;
  background: #fef0f0;
  border: 1rpx solid #fbc4c4;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  flex-shrink: 0;
}

.hot-tag text {
  font-size: 20rpx;
  font-weight: 800;
  color: #f56c6c;
}

/* 价格 + 热量行 */
.dish-bot {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #e67e22;
}

.dish-price-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #909399;
  margin-left: 2rpx;
}

.dish-kcal {
  font-size: 20rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f5f7fa;
  color: #909399;
}

/* 热量三色 */
.dish-kcal.cal-low {
  color: #57a52a;
  background: #ebf7e3;
}

.dish-kcal.cal-high {
  color: #d46b08;
  background: #fef0dc;
  font-weight: 700;
}

.dish-kcal.cal-mid {
  color: #909399;
  background: #f5f7fa;
}

/* ===== 健身动作 ===== */

/* ── Tier 1: 肌群大类横向滚动胶囊 ── */
.fitness-muscle-tabs {
  width: 100%;
  margin-bottom: 12rpx;
  white-space: nowrap;
}

.fitness-muscle-tabs-inner {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 0;
}

.fitness-muscle-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 2rpx solid #e4e7ed;
  font-size: 24rpx;
  font-weight: 500;
  color: #606266;
  flex-shrink: 0;
  transition: all 0.2s;
}

.fitness-muscle-tab:active {
  background: #f0f2f5;
}

.fitness-muscle-tab-active {
  background: linear-gradient(135deg, #f56c6c, #e63946);
  border-color: #e63946;
  color: #fff;
  font-weight: 700;
  box-shadow: 0 4rpx 16rpx rgba(230, 57, 70, 0.35);
}

/* ── Tier 2: 筛选工具栏 ── */
.fitness-filter-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.fitness-filter-dropdown {
  flex-shrink: 0;
}

.fitness-filter-chip {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 16rpx;
  background: #fff;
  border: 1rpx solid #dcdfe6;
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #606266;
}

.fitness-filter-chip:active {
  border-color: #409eff;
  background: #ecf5ff;
  color: #409eff;
}

.fitness-filter-ico {
  font-size: 22rpx;
}

.fitness-filter-arrow {
  font-size: 18rpx;
  color: #c0c4cc;
  margin-left: 2rpx;
}

/* 难度筛选行 */
.fitness-difficulty-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: nowrap;
}

.fitness-diff-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  background: #fff;
  border: 2rpx solid #e4e7ed;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #909399;
  flex-shrink: 0;
}

.fitness-diff-chip:active {
  border-color: #409eff;
  color: #409eff;
}

.fitness-diff-chip-active {
  border-color: #e6a23c;
  background: #fdf6ec;
  color: #b88230;
  font-weight: 700;
}

/* ── 筛选回显与清空 ── */
.fitness-filter-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10rpx 16rpx;
  background: #f0f9ff;
  border-radius: 10rpx;
  margin-bottom: 14rpx;
  border: 1rpx solid #d9ecff;
}

.fitness-filter-summary-text {
  font-size: 22rpx;
  color: #606266;
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-wrap: wrap;
}

.fitness-tag-selected {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  background: #409eff;
  color: #fff;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.fitness-clear-btn {
  padding: 6rpx 16rpx;
  background: #fff;
  border: 1rpx solid #f56c6c;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.fitness-clear-btn text {
  font-size: 20rpx;
  color: #f56c6c;
  font-weight: 600;
}

.fitness-clear-btn:active {
  background: #fef0f0;
}

/* ── Tier 3: 动作卡片网格 ── */
.fitness-action-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 单张动作卡片 */
.fitness-action-card {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 14rpx;
  overflow: hidden;
  box-shadow: 0 3rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #ebeef5;
}

.fitness-action-card:active {
  background: #fafbfc;
  transform: scale(0.985);
  transition: transform 0.15s;
}

/* 图片区域 */
.faction-img-wrap {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  background: #f2f3f5;
}

.faction-img {
  width: 100%;
  height: 100%;
}

.faction-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f56c6c, #e63946);
}

.faction-placeholder-ico {
  font-size: 48rpx;
}

.faction-video-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.faction-video-tag text {
  font-size: 18rpx;
  color: #fff;
}

/* 信息区域 */
.faction-info {
  flex: 1;
  padding: 16rpx 18rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
}

.faction-name-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.faction-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1d1f;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.faction-alias {
  font-size: 20rpx;
  color: #c0c4cc;
  flex-shrink: 0;
}

/* 标签行 */
.faction-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.faction-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.faction-tag-muscle {
  background: #fef0f0;
  color: #f56c6c;
  border: 1rpx solid #fbc4c4;
}

.faction-tag-equip {
  background: #edf2fc;
  color: #5470c6;
  border: 1rpx solid #d0d9f0;
}

.faction-tag-mode {
  background: #e8f5e9;
  color: #388e3c;
  border: 1rpx solid #c8e6c9;
}

/* 难度星级 */
.faction-difficulty {
  display: flex;
  gap: 4rpx;
}

.faction-star {
  font-size: 24rpx;
  color: #e4e7ed;
}

.faction-star-on {
  color: #e6a23c;
}

/* 右箭头 */
.faction-arrow-wrap {
  display: flex;
  align-items: center;
  padding: 0 12rpx;
  flex-shrink: 0;
}

.faction-arrow {
  font-size: 36rpx;
  font-weight: 300;
  color: #c0c4cc;
}
