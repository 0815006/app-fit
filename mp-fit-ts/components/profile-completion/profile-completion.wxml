<view class="profile-modal" wx:if="{{visible}}">
  <!-- 遮罩 -->
  <view class="mask" bindtap="onClose"></view>

  <!-- 底部抽屉 -->
  <view class="drawer">
    <text class="title">完善个人信息</text>
    <text class="desc">为了方便在后续服务中称呼您，请填写以下信息</text>

    <!-- 头像选择（wx.chooseMedia，兼容 Windows 模拟器和真机） -->
    <view class="avatar-wrapper" bindtap="onChooseAvatar">
      <image wx:if="{{ avatarUrl && !_avatarError }}" class="avatar" src="{{ avatarUrl }}" mode="aspectFill" binderror="onAvatarError"></image>
      <text wx:else class="avatar-placeholder">👤</text>
      <text class="avatar-hint">点击选择头像</text>
    </view>

    <!-- 昵称输入（type="nickname" 支持微信昵称键盘） -->
    <input
      type="nickname"
      class="name-input"
      placeholder="请输入您的名字或昵称"
      bindinput="onNameInput"
    />

    <!-- 隐私协议勾选区域 -->
    <view class="privacy-check">
      <button
        class="privacy-agree-btn"
        open-type="agreePrivacyAuthorization"
        bindagreeprivacyauthorization="handlePrivacyAgree"
      >
        <view class="checkbox {{ privacyAgreed ? 'checked' : '' }}">
          <text wx:if="{{ privacyAgreed }}">✓</text>
        </view>
        <text class="privacy-check-text">我已阅读并同意</text>
      </button>
      <text class="privacy-link" bindtap="goToPrivacy">《隐私保护指引》</text>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn" bindtap="submitProfile">开启体验</button>
  </view>
</view>
