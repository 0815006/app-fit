<wxs module="fmt">
  function formatPrice(price) {
    if (price === 0) return '免费'
    return '¥' + price.toFixed(2)
  }
  function getCalorieClass(kcal) {
    if (kcal <= 0) return ''
    if (kcal <= 100) return 'cal-low'
    if (kcal >= 500) return 'cal-high'
    return 'cal-mid'
  }
  function getMealColor(type) {
    if (type === '早餐') return '#e6a23c'
    if (type === '午餐') return '#e67e22'
    if (type === '晚餐') return '#8e44ad'
    if (type === '夜宵') return '#5b6abf'
    return '#e67e22'
  }
  module.exports = {
    formatPrice: formatPrice,
    getCalorieClass: getCalorieClass,
    getMealColor: getMealColor
  }
</wxs>

<view class="container">
  <scroll-view scroll-y class="main-scroll" style="height: {{ scrollHeight }}px">
  <!-- ========== 会议预定 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'meeting' }}">
    <!-- 加载中 -->
    <view class="loading-area" wx:if="{{ meetingLoading && !meetingDataReady }}">
      <text class="loading-text">加载会议室...</text>
    </view>

    <!-- 会议预定主体 -->
    <block wx:if="{{ meetingDataReady }}">
      <!-- ══════ 控制区 ══════ -->
      <view class="meeting-ctrl-wrap">
        <!-- 日期导航 -->
        <view class="date-row">
          <view class="date-arrow" bindtap="handleMeetingPrevDay">
            <text>◀ 前一天</text>
          </view>
          <picker mode="date" value="{{ meetingDate }}" bindchange="handleMeetingDateChange">
            <view class="date-display">
              <text>{{ meetingDateDisplay }}</text>
            </view>
          </picker>
          <view class="date-arrow" bindtap="handleMeetingNextDay">
            <text>后一天 ▶</text>
          </view>
        </view>
        <view class="back-home-row" wx:if="{{ !meetingIsToday }}">
          <view class="back-today-btn breathing" bindtap="goToMeetingToday">
            <text>⭕ 回到今天</text>
          </view>
        </view>

        <!-- 会议室选择器（横向滚动） -->
        <scroll-view scroll-x class="meeting-room-tabs" wx:if="{{ meetingRooms.length > 0 }}">
          <view class="meeting-room-tabs-inner">
            <view
              wx:for="{{ meetingRooms }}"
              wx:key="id"
              class="meeting-room-tab {{ meetingActiveRoomId === item.id ? 'meeting-room-tab-active' : '' }}"
              data-index="{{ index }}"
              bindtap="handleMeetingRoomChange"
            >
              <text class="meeting-room-tab-name">{{ item.name }}</text>
              <text class="meeting-room-tab-cap">容纳{{ item.capacity }}人</text>
            </view>
          </view>
        </scroll-view>
      </view>

      <!-- ══════ 时间网格 ══════ -->
      <view class="meeting-grid-wrap" wx:if="{{ meetingBoardData }}">
        <!-- 当前会议室信息条 + 视图切换 -->
        <view class="meeting-room-info-bar">
          <text class="meeting-room-info-name">📍 {{ meetingBoardData.roomName }}</text>
          <text class="meeting-room-info-cap">容纳 {{ meetingBoardData.capacity }} 人</text>
          <view class="meeting-room-info-facilities" wx:if="{{ meetingBoardData.facilities && meetingBoardData.facilities.length > 0 }}">
            <text
              wx:for="{{ meetingBoardData.facilities }}"
              wx:key="*this"
              wx:for-item="f"
              class="meeting-facility-tag"
            >{{ f }}</text>
          </view>
          <view class="meeting-view-toggle-inline" bindtap="handleMeetingViewToggle">
            <text>{{ meetingViewMode === 'name' ? '👤 预定人' : '📋 会议名' }}</text>
          </view>
        </view>

        <!-- 图例 -->
        <view class="meeting-legend">
          <view class="meeting-legend-item">
            <view class="meeting-legend-dot meeting-legend-free"></view>
            <text>空闲</text>
          </view>
          <view class="meeting-legend-item">
            <view class="meeting-legend-dot meeting-legend-mine"></view>
            <text>我的预定</text>
          </view>
          <view class="meeting-legend-item">
            <view class="meeting-legend-dot meeting-legend-booked"></view>
            <text>已预定</text>
          </view>
          <view class="meeting-legend-item">
            <view class="meeting-legend-dot meeting-legend-lock"></view>
            <text>征用</text>
          </view>
        </view>

        <!-- 时间网格表格（左整点标签 + 右两段左右并排，右侧只显示状态） -->
        <view class="meeting-grid-table">
          <block wx:for="{{ meetingBoardData.displayRows }}" wx:key="key" wx:for-item="row">
            <!-- 午间分隔线 -->
            <view wx:if="{{ row.type === 'divider' }}" class="meeting-divider">
              <view class="meeting-divider-line"></view>
              <text class="meeting-divider-text">午 休</text>
              <view class="meeting-divider-line"></view>
            </view>
            <!-- 正常时段行 -->
            <view wx:else class="meeting-hour-row">
              <!-- 左侧：整点标签 -->
              <view class="meeting-hour-label-col">
                <text class="meeting-hour-label">{{ row.hourLabel }}</text>
              </view>
              <!-- 右侧：两段格子左右并排 -->
              <view class="meeting-hour-cells">
                <!-- 第一段 -->
                <view
                  class="meeting-slot-cell meeting-slot-cell-{{ row.slots[0].type === 'MY_BOOKING' ? 'mine' : (row.slots[0].type === 'BOOKED' ? 'booked' : (row.slots[0].type === 'ADMIN_LOCK' ? 'lock' : 'free')) }} {{ row.slots[0].isPast ? 'meeting-slot-cell-past' : '' }}"
                  data-slot="{{ row.slots[0].slot }}"
                  bindtap="handleMeetingSlotClick"
                >
                  <block wx:if="{{ row.slots[0].type === 'FREE' }}">
                    <text class="meeting-slot-status-free">{{ row.slots[0].isNonWorkTime ? '非上班时间' : '空闲' }}</text>
                  </block>
                  <block wx:elif="{{ row.slots[0].type === 'MY_BOOKING' }}">
                    <text class="meeting-slot-name">{{ meetingViewMode === 'name' ? (row.slots[0].booking.empName || row.slots[0].booking.empNo) : (row.slots[0].booking.meetingTitle || '无标题') }}</text>
                    <view class="meeting-slot-weekly" wx:if="{{ row.slots[0].booking.isWeeklyFix }}"><text>🔄 周期</text></view>
                  </block>
                  <block wx:elif="{{ row.slots[0].type === 'BOOKED' }}">
                    <text class="meeting-slot-name">{{ meetingViewMode === 'name' ? (row.slots[0].booking.empName || row.slots[0].booking.empNo) : (row.slots[0].booking.meetingTitle || '无标题') }}</text>
                  </block>
                  <block wx:elif="{{ row.slots[0].type === 'ADMIN_LOCK' }}">
                    <text class="meeting-slot-name">🔒 {{ row.slots[0].lock.deptName || '行政征用' }}</text>
                    <text class="meeting-slot-sub">{{ row.slots[0].lock.reason }}</text>
                  </block>
                  <block wx:else>
                    <text class="meeting-slot-status-past">已过期</text>
                  </block>
                </view>
                <!-- 第二段 -->
                <view
                  wx:if="{{ row.slots[1] }}"
                  class="meeting-slot-cell meeting-slot-cell-{{ row.slots[1].type === 'MY_BOOKING' ? 'mine' : (row.slots[1].type === 'BOOKED' ? 'booked' : (row.slots[1].type === 'ADMIN_LOCK' ? 'lock' : 'free')) }} {{ row.slots[1].isPast ? 'meeting-slot-cell-past' : '' }}"
                  data-slot="{{ row.slots[1].slot }}"
                  bindtap="handleMeetingSlotClick"
                >
                  <block wx:if="{{ row.slots[1].type === 'FREE' }}">
                    <text class="meeting-slot-status-free">{{ row.slots[1].isNonWorkTime ? '非上班时间' : '空闲' }}</text>
                  </block>
                  <block wx:elif="{{ row.slots[1].type === 'MY_BOOKING' }}">
                    <text class="meeting-slot-name">{{ meetingViewMode === 'name' ? (row.slots[1].booking.empName || row.slots[1].booking.empNo) : (row.slots[1].booking.meetingTitle || '无标题') }}</text>
                    <view class="meeting-slot-weekly" wx:if="{{ row.slots[1].booking.isWeeklyFix }}"><text>🔄 周期</text></view>
                  </block>
                  <block wx:elif="{{ row.slots[1].type === 'BOOKED' }}">
                    <text class="meeting-slot-name">{{ meetingViewMode === 'name' ? (row.slots[1].booking.empName || row.slots[1].booking.empNo) : (row.slots[1].booking.meetingTitle || '无标题') }}</text>
                  </block>
                  <block wx:elif="{{ row.slots[1].type === 'ADMIN_LOCK' }}">
                    <text class="meeting-slot-name">🔒 {{ row.slots[1].lock.deptName || '行政征用' }}</text>
                    <text class="meeting-slot-sub">{{ row.slots[1].lock.reason }}</text>
                  </block>
                  <block wx:else>
                    <text class="meeting-slot-status-past">已过期</text>
                  </block>
                </view>
                <!-- 空占位 -->
                <view wx:else class="meeting-slot-cell meeting-slot-cell-free meeting-slot-cell-placeholder"></view>
              </view>
            </view>
          </block>
        </view>
      </view>

      <!-- 无会议室 -->
      <view class="menu-empty" wx:elif="{{ !meetingLoading && meetingRooms.length === 0 }}">
        <text class="empty-ico">🏢</text>
        <text class="empty-msg">暂无可用的会议室</text>
        <text class="empty-hint">请联系管理员添加会议室</text>
      </view>
    </block>
  </view>

  <!-- ========== 今日菜单 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'menu' }}">
    <!-- ══════ 三层控制区 ══════ -->
    <view class="menu-ctrl-wrap">
      <!-- Tier 1: 食堂分段控制器 -->
      <view class="segmented-ctrl">
        <view
          class="seg-btn {{ todayZone === '一期' ? 'seg-on' : '' }}"
          data-zone="一期"
          bindtap="handleTodayZoneChange"
        ><text>🏢 一期食堂</text></view>
        <view
          class="seg-btn {{ todayZone === '二期' ? 'seg-on' : '' }}"
          data-zone="二期"
          bindtap="handleTodayZoneChange"
        ><text>🏢 二期食堂</text></view>
      </view>

      <!-- Tier 2: 日期导航 -->
      <view class="date-row">
        <view class="date-arrow" bindtap="goToPrevDay">
          <text>◀ 前一天</text>
        </view>
        <picker mode="date" value="{{ todayDate }}" bindchange="handleTodayDateChange">
          <view class="date-display">
            <text>{{ todayDateDisplay }}</text>
          </view>
        </picker>
        <view class="date-arrow" bindtap="goToNextDay">
          <text>后一天 ▶</text>
        </view>
      </view>
      <view class="back-home-row" wx:if="{{ !isTodaySelected }}">
        <view class="back-today-btn breathing" bindtap="goToToday">
          <text>⭕ 回到今天</text>
        </view>
      </view>

      <!-- Tier 3: 餐次胶囊 -->
      <view class="capsule-row">
        <view
          wx:for="{{ todayMealTypes }}"
          wx:key="value"
          class="capsule capsule-{{ item.key }} {{ todayMealType === item.value ? 'capsule-on' : '' }}"
          data-type="{{ item.value }}"
          bindtap="handleTodayMealChange"
        >
          <text class="capsule-ico">{{ item.icon }}</text>
          <text class="capsule-lbl">{{ item.label }}</text>
        </view>
      </view>
    </view>

    <!-- ══════ 数据展示区 ══════ -->
    <!-- 骨架屏 -->
    <view class="menu-skel-grid" wx:if="{{ todayShowSkeleton }}">
      <view class="menu-skel-card" wx:for="{{ [1,2,3] }}" wx:key="*this">
        <view class="sk-head">
          <view class="sk-bar sk-bar-title"></view>
          <view class="sk-bar sk-bar-badge"></view>
        </view>
        <view class="sk-body">
          <block wx:for="{{ [1,2,3] }}" wx:key="*this">
            <view class="sk-row">
              <view class="sk-bar sk-bar-name"></view>
              <view class="sk-bar sk-bar-info"></view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="menu-empty" wx:elif="{{ !todayLoading && todayMenuRecords.length === 0 }}">
      <text class="empty-ico floating">🍽️</text>
      <text class="empty-msg">今日该餐次暂无菜单排期</text>
      <text class="empty-hint">去其他时段看看吧~</text>
    </view>

    <!-- 分类卡片 -->
    <view class="menu-grid" wx:else>
      <view
        class="menu-card"
        wx:for="{{ todayGrouped }}"
        wx:key="name"
      >
        <!-- 卡片头部 -->
        <view
          class="menu-card-head"
          style="border-bottom-color: {{ fmt.getMealColor(todayMealType) }};"
        >
          <text class="menu-card-title">{{ item.name }}</text>
          <text class="menu-card-num">共 {{ item.items.length }} 款</text>
        </view>

        <!-- 卡片内容 -->
        <view class="menu-card-body">
          <view
            class="dish {{ it.isSpicy === 1 ? 'dish-hot' : '' }}"
            wx:for="{{ item.items }}"
            wx:for-item="it"
            wx:key="id"
          >
            <!-- 菜品名 + 辣标签 -->
            <view class="dish-top">
              <text class="dish-name">{{ it.dishName }}</text>
              <view class="hot-tag" wx:if="{{ it.isSpicy === 1 }}">
                <text>🌶️ 辣</text>
              </view>
            </view>

            <!-- 价格 + 热量 -->
            <view class="dish-bot">
              <text class="dish-price">{{ fmt.formatPrice(it.price) }}<text wx:if="{{ it.unit }}" class="dish-price-unit">/{{ it.unit }}</text></text>
              <text
                wx:if="{{ it.energyKcal > 0 }}"
                class="dish-kcal {{ fmt.getCalorieClass(it.energyKcal) }}"
              >🔥 {{ it.energyKcal }} kcal</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 欢迎品尝卡片 -->
    <view class="welcome-card" wx:if="{{ !todayLoading }}">
      <view class="welcome-text">
        <text>🍽️ 欢迎品尝</text>
      </view>
    </view>
  </view>

  <!-- ========== 健身动作 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'fitness' }}">
    <!-- 骨架屏 -->
    <view class="menu-skel-grid" wx:if="{{ fitnessLoading }}">
      <view class="menu-skel-card" wx:for="{{ [1,2,3] }}" wx:key="*this">
        <view class="sk-head">
          <view class="sk-bar sk-bar-title"></view>
          <view class="sk-bar sk-bar-badge"></view>
        </view>
        <view class="sk-body">
          <block wx:for="{{ [1,2,3] }}" wx:key="*this">
            <view class="sk-row">
              <view class="sk-bar sk-bar-name"></view>
              <view class="sk-bar sk-bar-info"></view>
            </view>
          </block>
        </view>
      </view>
    </view>

    <!-- 加载完毕后的内容 -->
    <block wx:elif="{{ fitnessDataReady }}">
      <!-- ── Tier 1: 肌群大类 Tabs (横向滚动胶囊) ── -->
      <scroll-view scroll-x class="fitness-muscle-tabs" wx:if="{{ fitnessMuscleGroups.length > 0 }}">
        <view class="fitness-muscle-tabs-inner">
          <view
            wx:for="{{ fitnessMuscleGroups }}"
            wx:key="*this"
            class="fitness-muscle-tab {{ fitnessActiveMuscleGroup === item ? 'fitness-muscle-tab-active' : '' }}"
            data-group="{{ item }}"
            bindtap="handleFitnessMuscleGroupChange"
          >
            <text>{{ item }}</text>
          </view>
        </view>
      </scroll-view>

      <!-- ── Tier 2: 筛选工具栏 ── -->
      <view class="fitness-filter-bar">
        <!-- 器械类型 -->
        <view class="fitness-filter-dropdown">
          <picker
            mode="selector"
            range="{{ fitnessEquipmentTypes }}"
            value="{{ fitnessActiveEquipmentType ? fitnessEquipmentTypes.indexOf(fitnessActiveEquipmentType) : 0 }}"
            bindchange="handleFitnessEquipmentTypeChange"
          >
            <view class="fitness-filter-chip">
              <text class="fitness-filter-ico">🔧</text>
              <text>{{ fitnessActiveEquipmentType || '全部器械' }}</text>
              <text class="fitness-filter-arrow">▾</text>
            </view>
          </picker>
        </view>

        <!-- 运动模式 -->
        <view class="fitness-filter-dropdown">
          <picker
            mode="selector"
            range="{{ fitnessMovementPatterns }}"
            value="{{ fitnessActiveMovementPattern ? fitnessMovementPatterns.indexOf(fitnessActiveMovementPattern) : 0 }}"
            bindchange="handleFitnessMovementPatternChange"
          >
            <view class="fitness-filter-chip">
              <text class="fitness-filter-ico">🏃</text>
              <text>{{ fitnessActiveMovementPattern || '全部模式' }}</text>
              <text class="fitness-filter-arrow">▾</text>
            </view>
          </picker>
        </view>

        <!-- 难度 -->
        <view class="fitness-difficulty-row">
          <view
            wx:for="{{ fitnessDifficultyLevels }}"
            wx:key="value"
            class="fitness-diff-chip {{ fitnessActiveDifficultyLevel === item.value ? 'fitness-diff-chip-active' : '' }}"
            data-level="{{ item.value }}"
            bindtap="handleFitnessDifficultyChange"
          >
            <text>{{ item.label }}</text>
          </view>
        </view>
      </view>

      <!-- ── 已选筛选回显与清空 ── -->
      <view class="fitness-filter-summary" wx:if="{{ fitnessActiveEquipmentType || fitnessActiveMovementPattern || fitnessActiveDifficultyLevel > 0 }}">
        <text class="fitness-filter-summary-text">
          已筛选：
          <text wx:if="{{ fitnessActiveEquipmentType }}" class="fitness-tag-selected">🔧 {{ fitnessActiveEquipmentType }}</text>
          <text wx:if="{{ fitnessActiveMovementPattern }}" class="fitness-tag-selected">🏃 {{ fitnessActiveMovementPattern }}</text>
          <text wx:if="{{ fitnessActiveDifficultyLevel > 0 }}" class="fitness-tag-selected">⭐ Lv{{ fitnessActiveDifficultyLevel }}</text>
        </text>
        <view class="fitness-clear-btn" bindtap="handleFitnessClearFilters">
          <text>✕ 清除筛选</text>
        </view>
      </view>

      <!-- ── Tier 3: 动作卡片列表 ── -->
      <view class="fitness-action-grid" wx:if="{{ fitnessFilteredActions.length > 0 }}">
        <view
          class="fitness-action-card"
          wx:for="{{ fitnessFilteredActions }}"
          wx:key="id"
          data-id="{{ item.id }}"
          bindtap="navigateToActionDetail"
        >
          <!-- 卡片信息区 -->
          <view class="faction-info">
            <view class="faction-name-row">
              <text class="faction-name">{{ item.name }}</text>
              <text class="faction-alias" wx:if="{{ item.alias }}">{{ item.alias }}</text>
            </view>
            <!-- 标签行 -->
            <view class="faction-tags">
              <!-- 肌群标签 -->
              <view class="faction-tag faction-tag-muscle" wx:if="{{ fitnessActionMuscleGroupMap[item.id] }}">
                <text>💪 {{ fitnessActionMuscleGroupMap[item.id] }}</text>
              </view>
              <!-- 器械标签列表 -->
              <view
                wx:for="{{ fitnessActionEquipmentTypeMap[item.id] || [] }}"
                wx:key="*this"
                wx:for-item="etype"
                class="faction-tag faction-tag-equip"
              >
                <text>🔩 {{ etype }}</text>
              </view>
              <!-- 模式标签 -->
              <view class="faction-tag faction-tag-mode" wx:if="{{ item.movementPattern }}">
                <text>🏃 {{ item.movementPattern }}</text>
              </view>
            </view>
            <!-- 难度星级 -->
            <view class="faction-difficulty">
              <text
                wx:for="{{ [1,2,3] }}"
                wx:key="*this"
                class="faction-star {{ item.difficultyLevel >= item ? 'faction-star-on' : '' }}"
              >★</text>
            </view>
          </view>
          <!-- 右箭头 -->
          <view class="faction-arrow-wrap">
            <text class="faction-arrow">›</text>
          </view>
        </view>
      </view>

      <!-- 空结果 -->
      <view class="menu-empty" wx:elif="{{ fitnessFilteredActions.length === 0 }}">
        <text class="empty-ico">🏋️</text>
        <text class="empty-msg">没有找到匹配的动作</text>
        <text class="empty-hint">试试调整筛选条件吧~</text>
      </view>
    </block>
  </view>

  <!-- ========== 个人信息 ========== -->
  <view class="content-area" wx:if="{{ activeTab === 'tech' }}">
    <!-- 当前用户信息卡片（点击进入个人信息页） -->
    <view class="user-info-card" wx:if="{{ currentUser }}" bindtap="goToProfile">
      <view class="user-info-avatar">
        <image wx:if="{{ currentUser.avatarUrl }}" class="user-avatar-img" src="{{ currentUser.avatarUrl }}" mode="aspectFill" />
        <text wx:else class="user-avatar-placeholder">👤</text>
      </view>
      <view class="user-info-body">
        <text class="user-info-name">{{ currentUser.nickname || '未设置昵称' }}</text>
        <text class="user-info-hint">点击查看/编辑个人信息 →</text>
      </view>
      <view class="user-info-arrow">></view>
    </view>

    <!-- 登录统计卡片 -->
    <view class="stats-card">
      <view class="stats-row">
        <view class="stats-item">
          <text class="stats-value">{{ myLoginCount !== null ? myLoginCount : '--' }}</text>
          <text class="stats-label">我的登录次数</text>
        </view>
        <view class="stats-divider"></view>
        <view class="stats-item">
          <text class="stats-value stats-value-total">{{ totalLoginCount !== null ? totalLoginCount : '--' }}</text>
          <text class="stats-label">小程序总登录次数</text>
        </view>
      </view>
      <view class="stats-hint" wx:if="{{ statsLoading }}">
        <text>加载中...</text>
      </view>
    </view>

    <view class="card">
      <view class="card-header card-header-collapse" bindtap="toggleTechCollapse">
        <text class="card-title">👤 个人信息</text>
        <text class="collapse-arrow {{ techCollapsed ? '' : 'collapse-arrow-open' }}">▾</text>
      </view>
      <view class="tech-list" wx:if="{{ !techCollapsed }}">
        <view class="tech-row" wx:for="{{ techStack }}" wx:key="name">
          <view class="tech-left">
            <text class="tech-category">{{ item.category }}</text>
            <text class="tech-name">{{ item.name }}</text>
          </view>
          <view class="tech-right">
            <text class="tech-version">{{ item.version }}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  </scroll-view>

  <!-- 底部菜单栏 -->
  <view class="tab-bar">
    <view
      class="tab-item {{ activeTab === item.key ? 'tab-item-active' : '' }}"
      wx:for="{{ tabBars }}"
      wx:key="key"
      data-key="{{ item.key }}"
      bindtap="switchTab"
    >
      <text class="tab-icon">{{ item.icon }}</text>
      <text class="tab-label">{{ item.label }}</text>
    </view>
  </view>
  <!-- 资料完善弹窗 -->
  <profile-completion
    visible="{{ showProfileModal }}"
    bind:close="onProfileClose"
    bind:success="onProfileSuccess"
  />

  <!-- ══════ 会议预定弹窗 ══════ -->
  <view class="meeting-modal-mask" wx:if="{{ meetingShowBookingModal }}" bindtap="closeMeetingModal">
    <view class="meeting-modal" catchtap="noop">
      <!-- 标题栏 -->
      <view class="meeting-modal-header">
        <text class="meeting-modal-title">
          <block wx:if="{{ meetingBookingMode === 'create' }}">📅 预定会议</block>
          <block wx:elif="{{ meetingBookingMode === 'edit-mine' }}">✏️ 我的预定</block>
          <block wx:elif="{{ meetingBookingMode === 'view-others' }}">👀 查看预定</block>
          <block wx:elif="{{ meetingBookingMode === 'view-lock' }}">🔒 行政征用</block>
        </text>
        <view class="meeting-modal-close" bindtap="closeMeetingModal">
          <text>✕</text>
        </view>
      </view>

      <!-- 时间段信息 -->
      <view class="meeting-modal-time-info">
        <text class="meeting-modal-time-label">{{ meetingSelectedSlot.timeLabel }}</text>
        <text class="meeting-modal-time-dash"> - </text>
        <text class="meeting-modal-time-end">{{ meetingSelectedSlotEndLabel }}</text>
        <view class="meeting-modal-time-badge meeting-modal-badge-{{ meetingSelectedSlot.type === 'MY_BOOKING' ? 'mine' : (meetingSelectedSlot.type === 'BOOKED' ? 'booked' : (meetingSelectedSlot.type === 'ADMIN_LOCK' ? 'lock' : 'free')) }}">
          <text>{{ meetingSelectedSlot.type === 'FREE' ? '空闲' : (meetingSelectedSlot.type === 'MY_BOOKING' ? '我的预定' : (meetingSelectedSlot.type === 'BOOKED' ? '已预定' : '征用')) }}</text>
        </view>
      </view>

      <!-- 查看征用 -->
      <block wx:if="{{ meetingBookingMode === 'view-lock' }}">
        <view class="meeting-modal-section">
          <view class="meeting-modal-row">
            <text class="meeting-modal-label">征用部门</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.lock.deptName || '-' }}</text>
          </view>
          <view class="meeting-modal-row">
            <text class="meeting-modal-label">征用原因</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.lock.reason || '-' }}</text>
          </view>
        </view>
        <view class="meeting-modal-footer">
          <view class="meeting-modal-btn-cancel" bindtap="closeMeetingModal">
            <text>关闭</text>
          </view>
        </view>
      </block>

      <!-- 查看他人预定 -->
      <block wx:elif="{{ meetingBookingMode === 'view-others' }}">
        <view class="meeting-modal-section">
          <view class="meeting-modal-row">
            <text class="meeting-modal-label">预定人</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.booking.empName }} ({{ meetingSelectedSlot.booking.empNo }})</text>
          </view>
          <view class="meeting-modal-row">
            <text class="meeting-modal-label">会议标题</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.booking.meetingTitle || '-' }}</text>
          </view>
          <view class="meeting-modal-row">
            <text class="meeting-modal-label">参会人员</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.booking.attendees || '-' }}</text>
          </view>
          <view class="meeting-modal-row" wx:if="{{ meetingSelectedSlot.booking.isWeeklyFix }}">
            <text class="meeting-modal-label">周期</text>
            <text class="meeting-modal-value meeting-modal-tag-weekly">🔄 周期例会</text>
          </view>
        </view>
        <view class="meeting-modal-footer">
          <view class="meeting-modal-btn-cancel" bindtap="closeMeetingModal">
            <text>关闭</text>
          </view>
        </view>
      </block>

      <!-- 创建 / 编辑我的预定 -->
      <block wx:else>
        <view class="meeting-modal-section">
          <!-- 预定人信息 -->
          <view class="meeting-modal-row" wx:if="{{ meetingBookingMode === 'edit-mine' }}">
            <text class="meeting-modal-label">预定人</text>
            <text class="meeting-modal-value">{{ meetingSelectedSlot.booking.empName }} ({{ meetingSelectedSlot.booking.empNo }})</text>
          </view>
          <!-- 会议标题 -->
          <view class="meeting-modal-field">
            <text class="meeting-modal-label">会议标题</text>
            <input
              class="meeting-modal-input"
              placeholder="请输入会议标题"
              value="{{ meetingFormTitle }}"
              bindinput="onMeetingTitleInput"
              maxlength="100"
            />
          </view>
          <!-- 参会人员 -->
          <view class="meeting-modal-field">
            <text class="meeting-modal-label">参会人员</text>
            <input
              class="meeting-modal-input"
              placeholder="可选：参会人员姓名"
              value="{{ meetingFormAttendees }}"
              bindinput="onMeetingAttendeesInput"
              maxlength="200"
            />
          </view>
          <!-- 周期约（仅创建时） -->
          <view class="meeting-modal-field" wx:if="{{ meetingBookingMode === 'create' }}">
            <view class="meeting-modal-row">
              <text class="meeting-modal-label">周期例会</text>
              <switch
                class="meeting-modal-switch"
                checked="{{ meetingFormWeeklyEnabled }}"
                bindchange="onMeetingWeeklyToggle"
                color="#409eff"
              />
            </view>
            <view class="meeting-modal-field" wx:if="{{ meetingFormWeeklyEnabled }}">
              <text class="meeting-modal-label">持续周数</text>
              <input
                class="meeting-modal-input meeting-modal-input-sm"
                type="number"
                value="{{ meetingFormWeeklyWeeks }}"
                bindinput="onMeetingWeeklyInput"
                maxlength="1"
              />
              <text class="meeting-modal-hint ml-8">1~8 周</text>
            </view>
          </view>
        </view>

        <!-- 按钮区域 -->
        <view class="meeting-modal-footer">
          <view wx:if="{{ meetingBookingMode === 'create' }}" class="meeting-modal-footer-full">
            <view class="meeting-modal-btn-cancel" bindtap="closeMeetingModal">
              <text>取消</text>
            </view>
            <view class="meeting-modal-btn-primary" bindtap="handleMeetingCreate">
              <text>{{ meetingSaving ? '预定中...' : '确认预定' }}</text>
            </view>
          </view>
          <view wx:if="{{ meetingBookingMode === 'edit-mine' }}" class="meeting-modal-footer-edit">
            <view class="meeting-modal-btn-cancel" bindtap="handleMeetingCancelGroup">
              <text>一键取消后续</text>
            </view>
            <view class="meeting-modal-btn-danger" bindtap="handleMeetingCancel">
              <text>取消本次</text>
            </view>
            <view class="meeting-modal-btn-primary" bindtap="handleMeetingUpdate">
              <text>{{ meetingSaving ? '保存中...' : '保存修改' }}</text>
            </view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
