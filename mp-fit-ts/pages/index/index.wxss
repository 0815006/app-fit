/* ===== 全局 / 公共 ===== */

page {
  background: #f5f6f8;
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
}

.main-scroll {
  flex-shrink: 0;
  padding: 16rpx 0 0;
}

.content-area {
  padding-bottom: 12rpx;
}

/* 加载 */
.loading-area {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  font-size: 24rpx;
  color: #909399;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  padding: 22rpx 24rpx 16rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
}

/* 可折叠标题 */
.card-header-collapse {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.collapse-arrow {
  font-size: 22rpx;
  color: #909399;
  transition: transform 0.25s ease;
}

.collapse-arrow-open {
  transform: rotate(180deg);
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-label {
  font-size: 26rpx;
  color: #606266;
}

.info-value {
  font-size: 26rpx;
  color: #303133;
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
}

.tag-primary {
  background: #ecf5ff;
  color: #409eff;
  border: 1rpx solid #d9ecff;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #ebeef5;
  margin: 14rpx 24rpx;
}

/* 统计 */
.stat-area {
  text-align: center;
  padding: 24rpx 0 12rpx;
}

.count-number {
  font-size: 72rpx;
  font-weight: 700;
  color: #409eff;
}

.count-unit {
  font-size: 28rpx;
  color: #909399;
  margin-left: 6rpx;
}

.stat-hint {
  text-align: center;
  padding-bottom: 22rpx;
}

.stat-hint text {
  font-size: 20rpx;
  color: #c0c4cc;
}

/* 技术选型（关于子菜单展开内容） */
.about-tech-list {
  padding: 0 0 6rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fafbfc;
}

.tech-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tech-row:last-child {
  border-bottom: none;
}

.tech-left {
  display: flex;
  flex-direction: column;
}

.tech-category {
  font-size: 24rpx;
  color: #303133;
}

.tech-name {
  font-size: 20rpx;
  color: #909399;
  margin-top: 4rpx;
}

.tech-right { flex-shrink: 0; }

.tech-version {
  font-size: 22rpx;
  color: #c0c4cc;
  background: #f5f7fa;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.about-item-arrow-open {
  color: #409eff;
  font-weight: 700;
}

/* 底部菜单栏 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #fff;
  border-top: 1rpx solid #e4e7ed;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  color: #909399;
}

.tab-item-active { color: #409eff; }

.tab-icon  { font-size: 32rpx; }
.tab-label { font-size: 20rpx; margin-top: 2rpx; }

/* ===== 健身打卡入口枢纽 ===== */

/* ── 通用入口卡片 ── */
.workout-hub-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.workout-hub-card:active {
  background: #fafbfc;
  transform: scale(0.985);
  transition: transform 0.15s;
}

.hub-card-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.hub-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.hub-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #303133;
  line-height: 1.3;
}

.hub-card-desc {
  font-size: 22rpx;
  color: #909399;
  margin-top: 4rpx;
}

.hub-card-arrow {
  font-size: 36rpx;
  font-weight: 300;
  color: #c0c4cc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ── 下方双栏区域 ── */
.workout-hub-bottom {
  display: flex;
  gap: 20rpx;
}

/* ── 左侧列 ── */
.workout-hub-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ── 右侧列 ── */
.workout-hub-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* ── 今日打卡 ── */
.workout-hub-checkin {
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
  border-left: 6rpx solid #67c23a;
  padding: 20rpx 28rpx;
}

.workout-hub-checkin .hub-card-icon {
  font-size: 40rpx;
  margin-right: 0;
  margin-bottom: 10rpx;
}

.workout-hub-checkin .hub-card-arrow {
  align-self: flex-end;
  margin-top: auto;
  margin-left: 0;
}

/* ── 补记录 ── */
.workout-hub-makeup {
  border-left: 6rpx solid #e6a23c;
  padding: 14rpx 28rpx;
  flex: 0 0 auto;
}

.workout-hub-makeup .hub-card-icon {
  font-size: 32rpx;
}

.workout-hub-makeup .hub-card-title {
  font-size: 24rpx;
}

.workout-hub-makeup .hub-card-desc {
  font-size: 20rpx;
}

/* ── 本周健身记录 ── */
.workout-hub-weekly {
  flex: 1;
  flex-direction: column;
  align-items: flex-start;
  border-left: 6rpx solid #b37feb;
  padding: 20rpx 28rpx;
}

.workout-hub-weekly .hub-card-icon {
  font-size: 40rpx;
  margin-right: 0;
  margin-bottom: 10rpx;
}

.workout-hub-weekly .hub-card-arrow {
  align-self: flex-end;
  margin-top: auto;
  margin-left: 0;
}

/* ── 我的所有记录 ── */
.workout-hub-calendar {
  border-left: 6rpx solid #909399;
  padding: 14rpx 28rpx;
  flex: 0 0 auto;
}

.workout-hub-calendar .hub-card-icon {
  font-size: 32rpx;
}

.workout-hub-calendar .hub-card-title {
  font-size: 24rpx;
}

.workout-hub-calendar .hub-card-desc {
  font-size: 20rpx;
}

/* ===== 坚持榜双卡片 ===== */
.consistency-cards {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.consistency-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  max-height: 380rpx;
}

/* 连续打卡卡片：暖橙左边线 */
.cc-card-streak {
  border-left: 6rpx solid #e6a23c;
}

/* 累计打卡卡片：蓝色左边线 */
.cc-card-cumulative {
  border-left: 6rpx solid #409eff;
}

/* 卡片头部 */
.cc-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.cc-header-streak {
  background: linear-gradient(135deg, #fff7ed, #fff);
  border-bottom-color: #fed7aa;
}

.cc-header-cumulative {
  background: linear-gradient(135deg, #ecf5ff, #fff);
  border-bottom-color: #d9ecff;
}

.cc-header-icon {
  font-size: 36rpx;
}

.cc-header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #303133;
}

/* 卡片列表体（可滚动） */
.cc-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 0;
}

.cc-row {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-bottom: 1rpx solid #f7f7f7;
}

.cc-row:last-child {
  border-bottom: none;
}

.cc-rank-col {
  width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.cc-medal {
  font-size: 32rpx;
  line-height: 1;
}

.cc-rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #909399;
  background: #f5f6f8;
}

.cc-name {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-left: 8rpx;
}

.cc-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #409eff;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.cc-unit {
  font-size: 24rpx;
  font-weight: 400;
  color: #909399;
  margin-left: 2rpx;
}

.cc-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.cc-empty text {
  font-size: 22rpx;
  color: #c0c4cc;
}

/* 更多榜单入口 */
.more-ranking-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #409eff;
}

.more-ranking-entry:active {
  background: #fafbfc;
  transform: scale(0.985);
  transition: transform 0.15s;
}

.more-ranking-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #303133;
}

.more-ranking-arrow {
  font-size: 36rpx;
  font-weight: 300;
  color: #c0c4cc;
}

/* ===== 当前用户信息卡片 ===== */

.user-info-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-info-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 18rpx;
  background: linear-gradient(135deg, #e8eaed, #dcdfe6);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar-img {
  width: 100%;
  height: 100%;
}

.user-avatar-placeholder {
  font-size: 40rpx;
}

.user-info-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.user-info-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
  line-height: 1.3;
}

.user-info-hint {
  font-size: 22rpx;
  color: #909399;
  margin-top: 4rpx;
}

.user-info-arrow {
  flex-shrink: 0;
  font-size: 32rpx;
  color: #c0c4cc;
  margin-left: 12rpx;
  font-weight: 700;
}

/* ===== 登录统计卡片 ===== */

.stats-card {
  background: linear-gradient(135deg, #409eff, #337ecc);
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(64, 158, 255, 0.30);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stats-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.stats-value-total {
  font-size: 56rpx;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 6rpx;
  font-weight: 500;
}

.stats-divider {
  width: 2rpx;
  height: 64rpx;
  background: rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
}

.stats-hint {
  text-align: center;
  margin-top: 12rpx;
}

.stats-hint text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* ===== 收藏菜品入口卡片 ===== */

.fav-dish-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #e6a23c;
}

.fav-dish-entry:active {
  background: #fafbfc;
  transform: scale(0.985);
  transition: transform 0.15s;
}

.fav-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.fav-entry-icon {
  font-size: 48rpx;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.fav-entry-body {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.fav-entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #303133;
  line-height: 1.3;
}

.fav-entry-desc {
  font-size: 22rpx;
  color: #909399;
  margin-top: 4rpx;
}

.fav-entry-arrow {
  font-size: 36rpx;
  font-weight: 300;
  color: #c0c4cc;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ===== 关于区域 ===== */
.about-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.about-header {
  padding: 22rpx 24rpx 16rpx;
}

.about-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #303133;
}

.about-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.about-item:active {
  background: #f5f6f8;
}

.about-item-label {
  font-size: 28rpx;
  color: #303133;
}

.about-item-arrow {
  font-size: 36rpx;
  color: #c0c4cc;
  font-weight: 300;
}
