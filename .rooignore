# ============================================================
# .rooignore - Roo Code 忽略文件
# 基于 .gitignore 扩展，减少调用大模型的无关上下文内容
# ============================================================

# ============================================================
# 操作系统 & 编辑器
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# IDE
.idea/
*.iml
*.iws
*.ipr
out/
.vscode/
.project
.classpath
.settings/
.factorypath
.springBeans

# ============================================================
# 日志 & 临时文件
# ============================================================
*.log
*.tmp
*.bak
*.swp
*~

# ============================================================
# java-fit-server (Spring Boot + Maven)
# ============================================================
java-fit-server/target/
java-fit-server/.mvn/
java-fit-server/*.jar
java-fit-server/*.war

# ============================================================
# web-fit-vue (Vue 3 + Vite)
# ============================================================
web-fit-vue/node_modules/
web-fit-vue/dist/
web-fit-vue/.env.local
web-fit-vue/.env.*.local

# ============================================================
# mp-fit-ts (微信原生小程序 + TypeScript)
# ============================================================
mp-fit-ts/node_modules/
mp-fit-ts/miniprogram_npm/

# ============================================================
# 环境变量 & 敏感配置
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key

# ============================================================
# Roo Code 额外忽略（不影响 git，仅减少大模型上下文）
# 以下文件 git 可能追踪，但对 AI 编码上下文无用且体积大
# ============================================================

# 锁文件（体积大，不提供代码上下文价值）
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml

# TypeScript 编译缓存（如果存在）
*.tsbuildinfo

# 构建产物（如果 git 追踪时）
dist/
build/
.gradle/

# 图片 & 二进制资源（对代码理解无帮助）
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot
*.mp4
*.mp3
*.webm

# 文档文件（通常不需要作为上下文）
#*.md

# 生成的源代码映射
*.map
*.js.map
*.css.map