/* ===== 通用 ===== */

page {
  background: #f5f6f8;
}

/* 加载 */
.adetail-loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
}

.adetail-loading-text {
  font-size: 26rpx;
  color: #909399;
}

/* 错误 */
.adetail-error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.adetail-error-ico {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.adetail-error-msg {
  font-size: 26rpx;
  color: #909399;
}

/* 滚动区 */
.adetail-scroll {
  padding: 0 24rpx calc(120rpx + env(safe-area-inset-bottom));
}

/* ===== 顶部：多媒体轮播 ===== */

.adetail-media {
  position: relative;
  width: 100%;
  height: 600rpx;
  background: #1a1a2e;
  overflow: hidden;
}

.adetail-swiper {
  width: 100%;
  height: 100%;
}

.adetail-img {
  width: 100%;
  height: 100%;
}

/* 视频播放浮层 */
.adetail-video-overlay {
  position: absolute;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 14rpx 28rpx;
  background: rgba(0, 0, 0, 0.65);
  border-radius: 40rpx;
  backdrop-filter: blur(8rpx);
}

.adetail-play-btn {
  width: 48rpx;
  height: 48rpx;
  background: #f56c6c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.adetail-play-ico {
  font-size: 22rpx;
  color: #fff;
  margin-left: 3rpx;
}

.adetail-play-label {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 无图占位 */
.adetail-media-placeholder {
  width: 100%;
  height: 380rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2d2d44, #1a1a2e);
}

.adetail-placeholder-ico {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.adetail-placeholder-text {
  font-size: 24rpx;
  color: #909399;
}

/* ===== 中部：Section 通用 ===== */

.adetail-section {
  background: #fff;
  margin: 16rpx 24rpx;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #ebeef5;
}

.adetail-section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f2f3f5;
}

.adetail-section-icon {
  font-size: 28rpx;
}

.adetail-section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1d1f;
}

/* ── 器械清单 ── */

.adetail-equip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.adetail-equip-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 18rpx;
  background: linear-gradient(135deg, #edf2fc, #e8effa);
  border: 1rpx solid #d0d9f0;
  border-radius: 10rpx;
}

.adetail-equip-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #5470c6;
}

.adetail-equip-type {
  font-size: 20rpx;
  color: #909399;
  background: #f5f7fa;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

/* ── 肌肉参与区域 ── */

.adetail-muscle-group {
  margin-bottom: 16rpx;
}

.adetail-muscle-group:last-child {
  margin-bottom: 12rpx;
}

.adetail-muscle-label {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
  display: block;
}

.adetail-muscle-label.primary-label {
  color: #f56c6c;
}

.adetail-muscle-label.secondary-label {
  color: #909399;
}

.adetail-muscle-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.adetail-muscle-chip {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 主要肌群 - 红色/橙色高亮胶囊 */
.primary-chip {
  background: linear-gradient(135deg, #fef0f0, #fde2e2);
  border: 2rpx solid #f56c6c;
  color: #e63946;
  box-shadow: 0 3rpx 10rpx rgba(245, 108, 108, 0.25);
}

/* 协同肌群 - 浅灰/浅蓝细边框 */
.secondary-chip {
  background: #f5f7fa;
  border: 2rpx solid #e4e7ed;
  color: #606266;
}

/* ── AI 提示语 ── */

.adetail-muscle-tip {
  margin-top: 14rpx;
  padding: 14rpx 18rpx;
  background: linear-gradient(135deg, #faf0ff, #f5f0ff);
  border-left: 5rpx solid #8e44ad;
  border-radius: 0 10rpx 10rpx 0;
}

.adetail-tip-text {
  font-size: 22rpx;
  color: #606266;
  line-height: 1.6;
}

.adetail-tip-bold {
  font-weight: 700;
  color: #303133;
}

/* ── 动作要领 ── */

.adetail-guide-card {
  padding: 16rpx 20rpx;
  background: #fafbfc;
  border-radius: 10rpx;
  border: 1rpx solid #ebeef5;
}

.adetail-guide-text {
  font-size: 26rpx;
  color: #303133;
  line-height: 1.8;
  white-space: pre-line;
}

/* ── 安全提示 ── */

.adetail-safety-card {
  padding: 16rpx 20rpx;
  background: linear-gradient(135deg, #fef9e7, #fef5d4);
  border-radius: 10rpx;
  border: 2rpx solid #e6a23c;
}

.adetail-safety-text {
  font-size: 26rpx;
  color: #b88230;
  line-height: 1.8;
  font-weight: 600;
}

/* 底部占位 */
.adetail-bottom-spacer {
  height: 20rpx;
}

/* ===== 底部固定按钮 ===== */

.adetail-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 14rpx 24rpx;
  padding-bottom: calc(14rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e4e7ed;
  z-index: 100;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.adetail-add-plan-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 0;
  background: linear-gradient(135deg, #f56c6c, #e63946);
  border: none;
  border-radius: 14rpx;
  box-shadow: 0 6rpx 20rpx rgba(230, 57, 70, 0.4);
}

.adetail-add-plan-btn::after {
  display: none;
}

.adetail-btn-icon {
  font-size: 28rpx;
}

.adetail-btn-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
}

.adetail-add-plan-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}