/* 隐私授权弹窗组件样式 */

.privacy-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1100;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.dialog {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -60%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 56rpx 44rpx 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 28rpx;
}

.desc {
  font-size: 26rpx;
  color: #606266;
  line-height: 42rpx;
  text-align: center;
  margin-bottom: 12rpx;
}

.link {
  font-size: 26rpx;
  color: #409eff;
  line-height: 42rpx;
  text-align: center;
  margin-bottom: 20rpx;
  text-decoration: underline;
}

.btns {
  margin-top: 36rpx;
  display: flex;
  gap: 20rpx;
  width: 100%;
}

.btn-refuse {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #909399;
  background: #f5f7fa;
  border: none;
  border-radius: 12rpx;
  padding: 0;
}

.btn-refuse::after {
  border: none;
}

.btn-agree {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #fff;
  background: #409eff;
  border: none;
  border-radius: 12rpx;
  padding: 0;
}

.btn-agree::after {
  border: none;
}
