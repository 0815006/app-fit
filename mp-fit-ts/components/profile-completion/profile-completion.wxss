.profile-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.drawer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 48rpx 40rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 26rpx;
  color: #909399;
  margin-bottom: 40rpx;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  margin-bottom: 32rpx;
  line-height: 1;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: #f0f2f5;
  margin-bottom: 12rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 12rpx;
  color: #fff;
}

.avatar-hint {
  font-size: 24rpx;
  color: #409eff;
}

.name-input {
  width: 100%;
  height: 88rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #303133;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: #409eff;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn::after {
  border: none;
}

/* 隐私协议勾选区域 */
.privacy-check {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.privacy-agree-btn {
  display: flex;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  line-height: 1;
  font-size: 26rpx;
  color: #606266;
}

.privacy-agree-btn::after {
  border: none;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #dcdfe6;
  border-radius: 6rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
  background: #fff;
  box-sizing: border-box;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #409eff;
  border-color: #409eff;
}

.privacy-check-text {
  font-size: 26rpx;
  color: #606266;
}

.privacy-link {
  font-size: 26rpx;
  color: #409eff;
  margin-left: 4rpx;
}
